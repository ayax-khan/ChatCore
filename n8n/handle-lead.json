{
  "name": "Handle Lead Capture",
  "nodes": [
    {
      "name": "Webhook Trigger",
      "type": "n8n-nodes-base.webhook",
      "position": [250, 300],
      "parameters": {
        "path": "lead-capture",
        "responseMode": "onReceived"
      }
    },
    {
      "name": "HubSpot Create Contact",
      "type": "n8n-nodes-base.hubspot",
      "position": [450, 300],
      "parameters": {
        "resource": "contact",
        "operation": "create",
        "email": "{{$node[\"Webhook\"].json.email}}",
        "properties": {
          "firstname": "{{$node[\"Webhook\"].json.name}}",
          "hs_lead_status": "NEW"
        }
      }
    },
    {
      "name": "Send Email Notification",
      "type": "n8n-nodes-base.emailSend",
      "position": [650, 300],
      "parameters": {
        "fromEmail": "leads@chatcore.dev",
        "toEmail": "admin@example.com",
        "subject": "New Lead: {{$node[\"Webhook\"].json.email}}",
        "text": "New lead captured: {{$node[\"Webhook\"].json.email}}"
      }
    }
  ],
  "connections": {
    "Webhook": {
      "main": [[{"node": "HubSpot Create Contact", "type": "main"}]]
    },
    "HubSpot Create Contact": {
      "main": [[{"node": "Send Email Notification", "type": "main"}]]
    }
  }
}
