{
  "info": {
    "name": "ChatCore API",
    "description": "API for ChatCore AI Customer Support Chatbot Platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://api.chatcore.dev/api/v1"
    },
    {
      "key": "token",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"user@example.com\", \"password\": \"StrongPass123!\", \"business_name\": \"My Business\"}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\"email\": \"user@example.com\", \"password\": \"StrongPass123!\"}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/refresh",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\"refresh_token\": \"your-refresh-token\"}"
            }
          }
        }
      ]
    },
    {
      "name": "Sites",
      "item": [
        {
          "name": "List Sites",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/sites/",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
          }
        },
        {
          "name": "Create Site",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/sites/",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"url\": \"https://example.com\", \"name\": \"Example Site\"}"
            }
          }
        },
        {
          "name": "Get Site",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/sites/{{site_id}}",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
          }
        },
        {
          "name": "Delete Site",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/sites/{{site_id}}",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
          }
        },
        {
          "name": "Trigger Crawl",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/sites/{{site_id}}/crawl",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
          }
        }
      ]
    },
    {
      "name": "Chat",
      "item": [
        {
          "name": "Send Message",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/chat/",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"question\": \"What is your return policy?\", \"site_id\": 1, \"session_id\": \"test-session\"}"
            }
          }
        }
      ]
    },
    {
      "name": "Analytics",
      "item": [
        {
          "name": "Usage",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/analytics/usage",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
          }
        },
        {
          "name": "Top Questions",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/analytics/top-questions",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
          }
        },
        {
          "name": "Cost Breakdown",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/analytics/cost-breakdown",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
          }
        }
      ]
    },
    {
      "name": "Billing",
      "item": [
        {
          "name": "Get Subscription",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/billing/subscription",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
          }
        },
        {
          "name": "List Plans",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/billing/plans",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
          }
        },
        {
          "name": "List Invoices",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/billing/invoices",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
          }
        }
      ]
    },
    {
      "name": "Security",
      "item": [
        {
          "name": "Audit Logs",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/security/audit-logs",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
          }
        },
        {
          "name": "GDPR Export",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/security/gdpr/export",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}]
          }
        }
      ]
    }
  ]
}
